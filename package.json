{
  "name": "pi-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal Pi extensions and skills.",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "extensions/*/index.ts",
      "!extensions/_*/**"
    ],
    "skills": [
      "skills/*",
      "!skills/_*"
    ]
  },
  "scripts": {
    "check": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
